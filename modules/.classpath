<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="src" output="lcdp/classes" path="lcdp/src/private"/>
	<classpathentry kind="src" output="webrt/classes" path="webrt/src/private"/>
	<classpathentry kind="src" output="riart/classes" path="riart/src/public"/>
